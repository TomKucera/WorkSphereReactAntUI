{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "react-jsx",

    // ✅ Recommended additions:
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "types": ["vite/client"],

    // ✅ Alias config
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules"],
  "references": []
}
